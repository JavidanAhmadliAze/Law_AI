# ============================================================================
# Law-AI environment — copy to .env and fill in. Nested keys use "__".
# ============================================================================

# --- App ---
APP__ENV=local                     # local | staging | prod
APP__DEBUG=true
APP__LOG_LEVEL=INFO
APP__SECRET_KEY=change-me          # JWT signing key
APP__ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Postgres (users + conversations + LangGraph checkpoints) ---
POSTGRES__HOST=localhost
POSTGRES__PORT=5434                # host-mapped port (5432 inside compose network)
POSTGRES__USER=lawai
POSTGRES__PASSWORD=lawai
POSTGRES__DB=lawai
POSTGRES__POOL_SIZE=10

# --- OpenSearch (hybrid index: dense + sparse, rerank pipeline) ---
OPENSEARCH__HOST=localhost
OPENSEARCH__PORT=9200
OPENSEARCH__USER=
OPENSEARCH__PASSWORD=
OPENSEARCH__USE_SSL=false
OPENSEARCH__INDEX=law-chunks
OPENSEARCH__SEARCH_PIPELINE=hybrid-rrf

# --- LLM (provider + model are free-form; nothing is hardcoded in code) ---
LLM__PROVIDER=                     # anthropic | bedrock | ...
LLM__MODEL=
LLM__API_KEY=
LLM__BASE_URL=
LLM__TEMPERATURE=0.0

# --- Embedding ---
EMBEDDING__MODEL=                  # e.g. BAAI/bge-m3 or a Bedrock model id
EMBEDDING__PROVIDER=local          # local | api | bedrock
EMBEDDING__API_URL=
EMBEDDING__DIMENSION=1024

# --- Reranker ---
RERANKER__MODEL=                   # e.g. BAAI/bge-reranker-v2-m3
RERANKER__PROVIDER=local           # local | api | bedrock
RERANKER__TOP_K=5

# --- Translation ---
TRANSLATION__MODEL=                # NMT model id (optional; LLM fallback used if empty)
TRANSLATION__PROVIDER=llm          # glossary-only | model | llm

# --- S3 (raw + parsed PDFs; optional locally) ---
S3__BUCKET=
S3__REGION=eu-central-1
S3__ENDPOINT_URL=                  # set for minio/localstack

# --- Langfuse (tracing) ---
LANGFUSE__PUBLIC_KEY=
LANGFUSE__SECRET_KEY=
LANGFUSE__HOST=https://cloud.langfuse.com
LANGFUSE__ENABLED=false

# --- Fetcher (offline pipeline) ---
# ISAP consolidated PDF of the Polish Constitution (Dz.U. 1997 nr 78 poz. 483)
FETCHER__CONSTITUTION_URL=https://isap.sejm.gov.pl/isap.nsf/download.xsp/WDU19970780483/U/D19970483Lj.pdf
